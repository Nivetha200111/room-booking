# ── Shared (multi-user) mode — Neon Postgres ────────────────────────────────
# Server-side only (used by the /api functions). Never exposed to the browser.
# Neon dashboard → your project → Connection string (pooled).
DATABASE_URL=

# Client flag: set to 'true' to make the app use the /api backend.
# Leave empty/false to run local-only (localStorage, no sharing).
VITE_USE_API=true
